{
"name": "taskpilot",
"version": "1.0.0",
"description": "TaskPilot - Navigate Your Work Efficiently",
"main": "main.js",
"scripts": {
"start": "electron .",
"build:win": "electron-builder --win --x64"
},
"devDependencies": {
"electron": "28.3.3",
"electron-builder": "^24.13.3",
"xlsx": "^0.18.5"
},
"build": {
"appId": "com.taskpilot.app",
"productName": "TaskPilot",
"directories": {
"output": "dist"
},
"files": [
"main.js",
"preload.js",
"src/**/*"
],
"win": {
"target": [
"nsis",
"portable"
],
"icon": "assets/icon.ico"
}
}
}
